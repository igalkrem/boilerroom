# Google OAuth2 — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Meta (Facebook) OAuth2 — create app at https://developers.facebook.com/apps/
# Required permissions: ads_read
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

# Snapchat OAuth2 — get these from Snap Business Manager > App Settings
# NOTE: Redirect URI must be set to /api/auth/snapchat/callback in Snap app settings
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:3000/api/auth/snapchat/callback

# Session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_64_char_random_hex_string
SESSION_COOKIE_NAME=snap_ads_session

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Snapchat API (no need to change these)
SNAPCHAT_API_BASE_URL=https://adsapi.snapchat.com/v1
SNAPCHAT_AUTH_URL=https://accounts.snapchat.com/login/oauth2/authorize
SNAPCHAT_TOKEN_URL=https://accounts.snapchat.com/login/oauth2/access_token

# Performance dashboard — Visymo reporting API (internal name; partner hostname/env var name unchanged)
KINGSROAD_API_TOKEN=     # Bearer token from Visymo Profile → API Credentials tab

# Performance dashboard — Predicto reporting API (optional — sync skipped if not set)
PREDICTO_API_TOKEN=

# Vercel Blob storage — from Vercel Dashboard → Storage → boilerroom-silo → .env.local tab
BLOB_READ_WRITE_TOKEN=

# Cron authentication — Vercel Pro auto-injects this; add manually for local cron testing
CRON_SECRET=

# Performance dashboard — Vercel Postgres (populated automatically by: vercel env pull .env.local)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
